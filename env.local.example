# Copier vers .env.local pour le développement local :
#   cp env.local.example .env.local
#
# Les variables ci-dessous complètent .env (ne pas commiter .env.local)

# ============================================
# Mode maintenance (test développement)
# ============================================
# true = tous les visiteurs voient la page maintenance (middleware Next.js)
# Redémarrer obligatoire après changement : pm2 restart amakifr-dev --update-env
MAINTENANCE_MODE=false

# IPs autorisées à contourner la maintenance (séparées par des virgules)
# Ne PAS mettre 127.0.0.1 si vous voulez tester la page en local
MAINTENANCE_BYPASS_IPS=

# Port local (cohérent avec package.json "dev" et PM2 amakifr-dev)
PORT=9052
